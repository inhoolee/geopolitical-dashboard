# ACLED credentials (required for conflict event data)
# Register at https://acleddata.com/register/
# Pipeline skips ACLED gracefully if unset.
# OAuth token auth (recommended)
ACLED_USERNAME=your_registered_email@example.com
ACLED_PASSWORD=your_account_password_here
# Optional override (default: acled)
ACLED_CLIENT_ID=acled

# Optional: override default warehouse path
# WAREHOUSE_PATH=/custom/path/geopolitical.duckdb
